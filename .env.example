# ── Required ──────────────────────────────────────────────────────────────────

# Groq API key — free at https://console.groq.com (no credit card needed)
GROQ_API_KEY=gsk_your_key_here

# ── Optional ──────────────────────────────────────────────────────────────────

# Path to SQLite policy database (default: data/policies.db)
# DB_PATH=data/policies.db

# Path to production decision log (default: data/production_log.jsonl)
# PRODUCTION_LOG_PATH=data/production_log.jsonl

# Path to shadow deployment log (default: data/shadow_log.jsonl)
# SHADOW_LOG_PATH=data/shadow_log.jsonl

# FastAPI host/port (default: 0.0.0.0:8000)
# API_HOST=0.0.0.0
# API_PORT=8000
